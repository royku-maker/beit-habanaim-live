</script>
<script>
  // Sample JSON object containing the URL
  var pageSettings = {
      "homepageUrl": window.location.href
  };

  // Function to clean the URL
  function cleanUrl(jsonObj) {
      var url = jsonObj.homepageUrl;

      // Create a regex pattern to match both "?language=eng" and "?language=heb"
      var newUrl = url.replace(/(\?language=eng|&language=eng|&language=heb|\?language=heb)/, "");

      // Ensure no trailing '?' or '&' left in the URL
      newUrl = newUrl.replace(/(\?|\&)$/, '');

      // Update the browser URL without reloading the page
      if (newUrl !== url) {
          window.history.replaceState({}, document.title, newUrl);
      }
  }

  // Call the function and pass the JSON object
  cleanUrl(pageSettings);
</script>

<script>
document.addEventListener("DOMContentLoaded", function() {
  const isHome =
    location.pathname === "/" || location.pathname === "/index.html" || location.pathname === "/index.php";
  const seoLink = document.getElementById("seo-link-container");
  if (!isHome && seoLink) {
    seoLink.style.display = "none";
  }
});
</script>

