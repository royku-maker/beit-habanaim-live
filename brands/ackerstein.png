        <script>
          (function () {
            const control = document.getElementById("interests-control");
            const head = document.getElementById("interests-head");
            const body = document.getElementById("interests-body");
            let show = false;

            function toggleInterests() {
              show = !show;
              body.style.display = show ? "block" : "none";
              head.setAttribute("aria-expanded", show.toString());
            }

            // Клик мышкой
            head.addEventListener("click", toggleInterests);

            // Поддержка Enter и Space
            head.addEventListener("keydown", function (e) {
              if (e.key === "Enter" || e.key === " ") {
                e.preventDefault();
                toggleInterests();
              }
            });

            // Закрытие при клике вне
            document.addEventListener("click", function (event) {
              if (!show) return;
              if (control.contains(event.target)) return;
              show = false;
              body.style.display = "none";
              head.setAttribute("aria-expanded", "false");
            });
          })();
        </script>

